"""
AI Workbench Admin Dashboard — Sprint 3 (profile_options + Basic Auth)
Runs on cp01, port 8888

Schema change: image_tag (single) → image_options (list)
Backward compatible: callable handles both formats.

profile_options allows users to pick image variant at spawn time:
  CPU Standard → [scipy-2024 ▼] or [datascience-2024 ▼]

Access: HTTP Basic Auth — credentials injected via systemd env vars
  DASHBOARD_USER (default: admin)
  DASHBOARD_PASS (required — set in workbench-admin.service)
"""

import base64
import json
import os
import re
import subprocess
import yaml
from datetime import datetime
from functools import wraps

import urllib.request
from flask import Flask, Response, jsonify, request, render_template_string

# ── Config ────────────────────────────────────────────────────────────────────

REGISTRY_CONF_PATH = os.path.expanduser("~/workbench-admin/registry.conf")
GITLAB_TOKEN       = os.environ.get("GITLAB_TOKEN", "")
CONFIGMAP_NAME     = "jupyterhub-profiles"
CONFIGMAP_NS       = "jhub"
DASHBOARD_USER     = os.environ.get("DASHBOARD_USER", "admin")
DASHBOARD_PASS     = os.environ.get("DASHBOARD_PASS", "")

def load_registry_conf():
    with open(REGISTRY_CONF_PATH) as f:
        conf = yaml.safe_load(f)
    return conf["registry"]

def gitlab_url():
    return load_registry_conf().get("gitlab_url", "http://10.110.188.61")

def registry_project_id():
    return load_registry_conf().get("project_id", 2)

# ── Basic Auth ────────────────────────────────────────────────────────────────

def require_auth(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        auth = request.headers.get("Authorization", "")
        if auth.startswith("Basic "):
            try:
                decoded  = base64.b64decode(auth[6:]).decode("utf-8")
                username, password = decoded.split(":", 1)
                if username == DASHBOARD_USER and password == DASHBOARD_PASS:
                    return f(*args, **kwargs)
            except Exception:
                pass
        return Response(
            "Authentication required.",
            401,
            {"WWW-Authenticate": 'Basic realm="AI Workbench Admin"'}
        )
    return decorated

# ── GitLab API ────────────────────────────────────────────────────────────────

def gitlab_get(path):
    url = f"{gitlab_url()}/api/v4/{path}"
    req = urllib.request.Request(url, headers={"PRIVATE-TOKEN": GITLAB_TOKEN})
    try:
        with urllib.request.urlopen(req, timeout=8) as resp:
            return json.loads(resp.read())
    except Exception as e:
        return {"error": str(e)}

# ── ConfigMap read/write ──────────────────────────────────────────────────────

def read_profiles():
    result = subprocess.run(
        ["kubectl", "get", "configmap", CONFIGMAP_NAME,
         "-n", CONFIGMAP_NS, "-o", "jsonpath={.data.profiles\\.json}"],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        return []
    try:
        data = json.loads(result.stdout.strip())
        return data if isinstance(data, list) else []
    except Exception:
        return []

def write_profiles(profiles):
    json_str = json.dumps(profiles, indent=2)
    patch    = {"data": {"profiles.json": json_str}}
    result   = subprocess.run(
        ["kubectl", "patch", "configmap", CONFIGMAP_NAME,
         "-n", CONFIGMAP_NS, "--type=merge", "--patch", json.dumps(patch)],
        capture_output=True, text=True
    )
    return result.returncode == 0, result.stdout + result.stderr

