<script>
function nav(name, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('nav a').forEach(a => a.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  el.classList.add('active');
  if (name === 'profiles') loadProfiles();
  if (name === 'new') { loadGroups(); loadRepos(); }
}

async function loadProfiles() {
  const grid = document.getElementById('profile-grid');
  const res  = await fetch('/api/profiles');
  const profiles = await res.json();
  if (!profiles.length) {
    grid.innerHTML = '<div class="empty">No profiles yet. Use "New Profile" to add one.</div>';
    return;
  }
  grid.innerHTML = profiles.map(p => {
    const tags = p.image_options || (p.image_tag ? [p.image_tag] : []);
    const badges = tags.map(t => `<span class="img-badge">${t}</span>`).join('');
    return `<div class="pc">
      <div class="name">${p.display_name}</div>
      <div class="grp">${p.gitlab_group}</div>
      <div class="meta">
        CPU: ${p.cpu_guarantee}–${p.cpu_limit} &nbsp;|&nbsp; RAM: ${p.mem_guarantee}–${p.mem_limit}<br>
        GPU: ${p.gpu || 'none'}<br>
        ${p.description ? '<em>' + p.description + '</em>' : ''}
      </div>
      <div class="imgs">${badges}</div>
      <div class="repo">${p.image_name}</div>
      <div class="actions">
        <button class="btn btn-danger" onclick="deleteProfile('${p.slug}')">Delete</button>
      </div>
    </div>`;
  }).join('');
}

async function deleteProfile(slug) {
  if (!confirm('Delete "' + slug + '"?')) return;
  await fetch('/api/profiles/' + slug, { method: 'DELETE' });
  loadProfiles();
}

async function applyProfiles() {
  const btn = document.querySelector('.btn-apply');
  const box = document.getElementById('apply-status');
  btn.disabled = true;
  btn.innerHTML = '<span class="spin"></span>Applying…';
  box.style.display = 'none';
  const res  = await fetch('/api/apply', { method: 'POST' });
  const data = await res.json();
  box.style.display = 'block';
  box.className = 'status ' + (data.success ? 'ok' : 'err');
  box.textContent = data.message;
  btn.disabled = false;
  btn.innerHTML = 'Apply to Cluster';
}

async function loadGroups() {
  const sel = document.getElementById('f-group');
  sel.innerHTML = '<option>Loading…</option>';
  const res = await fetch('/api/gitlab/groups');
  const groups = await res.json();
  if (groups.error) { sel.innerHTML = '<option>Failed to load</option>'; return; }
  sel.innerHTML = groups
    .filter(g => g.path !== 'registry')
    .map(g => `<option value="${g.path}">${g.full_path}</option>`)
    .join('');
}

async function loadRepos() {
  const sel = document.getElementById('f-repo');
  sel.innerHTML = '<option value="">Loading…</option>';
  const res   = await fetch('/api/registry/repos');
  const repos = await res.json();
  if (repos.error) { sel.innerHTML = '<option value="">Failed to load</option>'; return; }
  sel.innerHTML = '<option value="">— select repository —</option>' +
    repos.map(r => `<option value="${r.id}" data-name="${r.name}">${r.name}</option>`).join('');
}

async function loadTags() {
  const repoSel = document.getElementById('f-repo');
  const tagDiv  = document.getElementById('tag-list');
  const repoId  = repoSel.value;
  if (!repoId) { tagDiv.innerHTML = '<span class="tag-empty">Select a repository first</span>'; return; }
  tagDiv.innerHTML = '<span class="tag-empty">Loading…</span>';
  const res  = await fetch('/api/registry/repos/' + repoId + '/tags');
  const tags = await res.json();
  if (!tags.length) { tagDiv.innerHTML = '<span class="tag-empty">No tags found</span>'; return; }
  tagDiv.innerHTML = tags.map(t =>
    `<label class="tag-item"><input type="checkbox" name="img-tag" value="${t.name}"/> ${t.name}</label>`
  ).join('');
}

function getSelectedTags() {
  return [...document.querySelectorAll('input[name="img-tag"]:checked')].map(cb => cb.value);
}

document.addEventListener('DOMContentLoaded', () => {
  loadProfiles();
  document.getElementById('f-name').addEventListener('input', function() {
    document.getElementById('f-slug').value = this.value
      .toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').slice(0, 48);
  });
});

async function createProfile() {
  const repoSel  = document.getElementById('f-repo');
  const repoName = repoSel.options[repoSel.selectedIndex]?.dataset?.name || '';
  const msg      = document.getElementById('create-msg');
  const tags     = getSelectedTags();

  const body = {
    slug:          document.getElementById('f-slug').value.trim(),
    display_name:  document.getElementById('f-name').value.trim(),
    description:   document.getElementById('f-desc').value.trim(),
    gitlab_group:  document.getElementById('f-group').value,
    image_name:    repoName,
    image_options: tags,
    cpu_limit:     parseFloat(document.getElementById('f-cpu-lim').value),
    cpu_guarantee: parseFloat(document.getElementById('f-cpu-req').value),
    mem_limit:     document.getElementById('f-mem-lim').value.trim(),
    mem_guarantee: document.getElementById('f-mem-req').value.trim(),
    gpu:           parseInt(document.getElementById('f-gpu').value) || 0,
  };

  if (!body.slug || !body.display_name || !body.gitlab_group || !body.image_name) {
    showMsg(msg, '✗ Fill in all required fields.', false); return;
  }
  if (!body.image_options.length) {
    showMsg(msg, '✗ Select at least one image tag.', false); return;
  }

  const res  = await fetch('/api/profiles', {
    method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body)
  });
  const data = await res.json();
  if (res.ok) {
    showMsg(msg, '✓ Profile added — go to Profiles and click Apply.', true);
  } else {
    showMsg(msg, '✗ ' + data.error, false);
  }
}

function showMsg(el, text, ok) {
  el.textContent = text;
  el.style.color = ok ? '#68d391' : '#fc8181';
  el.style.display = 'inline';
  if (ok) setTimeout(() => el.style.display = 'none', 4000);
}
</script>
