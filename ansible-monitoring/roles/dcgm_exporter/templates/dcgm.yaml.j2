# ansible-monitoring/roles/dcgm_exporter/templates/dcgm.yaml.j2
#
# NVIDIA DCGM Exporter DaemonSet
#
# Runs on GPU nodes only and exposes GPU telemetry (utilisation, memory,
# temperature, power, clock speed) on port {{ dcgm_metrics_port }}.
# Prometheus scrapes these metrics; Grafana visualises them.
#
# nodeSelector — how GPU nodes are identified
# -------------------------------------------
# Controlled by dcgm_node_selector_key / dcgm_node_selector_value (group_vars/all.yml).
# The label nvidia.com/gpu.present=true was written by old standalone GFD (NVDP < 0.14).
# Newer NVDP/GFD versions dropped it. Default is nvidia.com/gpu.mode=compute which
# is written by all modern GFD versions on any compute GPU node.
---
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: dcgm-exporter
  namespace: {{ dcgm_namespace }}
  labels:
    app: dcgm-exporter
spec:
  selector:
    matchLabels:
      app: dcgm-exporter
  template:
    metadata:
      labels:
        app: dcgm-exporter
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "{{ dcgm_metrics_port }}"
    spec:
      # Only schedule on nodes where dcgm_node_selector_key=dcgm_node_selector_value.
      # Default: nvidia.com/gpu.mode=compute (GFD label, present on all compute GPU nodes).
      # Override dcgm_node_selector_key / dcgm_node_selector_value in group_vars/all.yml
      # if your GFD version writes a different discriminating label.
      nodeSelector:
        {{ dcgm_node_selector_key }}: "{{ dcgm_node_selector_value }}"

      tolerations:
        - key: nvidia.com/gpu
          operator: Exists
          effect: NoSchedule

      containers:
        - name: dcgm-exporter
          image: nvcr.io/nvidia/k8s/dcgm-exporter:{{ dcgm_version }}
          ports:
            - name: metrics
              containerPort: {{ dcgm_metrics_port }}
          securityContext:
            runAsNonRoot: false
            privileged: true
          volumeMounts:
            - name: pod-gpu-resources
              readOnly: true
              mountPath: /var/lib/kubelet/pod-resources

      volumes:
        - name: pod-gpu-resources
          hostPath:
            path: /var/lib/kubelet/pod-resources

---
apiVersion: v1
kind: Service
metadata:
  name: dcgm-exporter
  namespace: {{ dcgm_namespace }}
  labels:
    app: dcgm-exporter
spec:
  # Headless — Prometheus discovers and scrapes each pod IP directly
  clusterIP: None
  selector:
    app: dcgm-exporter
  ports:
    - name: metrics
      port: {{ dcgm_metrics_port }}
      targetPort: {{ dcgm_metrics_port }}
