# ansible-monitoring/roles/prometheus_stack/templates/values.yaml.j2
#
# This file customises the kube-prometheus-stack Helm chart.
# It is rendered by Ansible at deploy time into /tmp/monitoring-values.yaml
# and passed to `helm upgrade --install` via the -f flag.
#
# What the chart installs for us (we do not manage these directly):
#   - Prometheus            — metrics database and query engine
#   - Alertmanager          — alert routing and deduplication
#   - Grafana               — dashboard and visualisation UI
#   - Prometheus Operator   — manages Prometheus/Alertmanager as CRDs
#   - kube-state-metrics    — exposes Kubernetes object state as metrics
#   - node-exporter         — exposes per-node OS/hardware metrics
#
# What this file does:
#   - Sets NodePort values so Grafana and Prometheus are reachable externally
#   - Conditionally provisions Grafana dashboards for GPU monitoring
#   - Conditionally configures Prometheus to scrape DCGM Exporter
#
# GPU monitoring (DCGM) is OPTIONAL and controlled by deploy_dcgm at runtime.
# When deploy_dcgm=false (default), all GPU-specific blocks below are omitted.
# When deploy_dcgm=true, the DCGM scrape job and the NVIDIA dashboard are added.

# ── Grafana ────────────────────────────────────────────────────────────────────
grafana:
  service:
    type: NodePort
    nodePort: {{ grafana_nodeport }}

{% if deploy_dcgm | default(false) | bool %}
  # ── Grafana dashboard provisioning (GPU only) ──────────────────────────────
  # Grafana supports automatic dashboard provisioning through configuration files.
  # Rather than clicking through the Grafana UI, we declare dashboards here and
  # Grafana imports them on startup — fully reproducible with no manual steps.
  #
  # dashboardProviders: tells Grafana WHERE to look for dashboard JSON files.
  #   Each provider defines a folder name and a filesystem path inside the
  #   Grafana container. The chart creates the folder and mounts the files.
  #
  # dashboards: the actual dashboards to provision, referenced by gnetId.
  #   gnetId is a Grafana.com dashboard ID. Grafana downloads the dashboard
  #   JSON from https://grafana.com/grafana/dashboards/<gnetId> at startup.
  #   gnetId 12239 = the official NVIDIA DCGM Exporter dashboard, which shows:
  #     GPU utilisation, framebuffer memory, temperature, power draw, clock speed.
  #
  # To add a custom dashboard instead of a gnetId:
  #   1. Export your dashboard JSON from Grafana UI (Dashboard → Share → Export)
  #   2. Save it to ansible-monitoring/roles/prometheus_stack/files/my-dashboard.json
  #   3. Replace gnetId with: json: "{% raw %}{{ lookup('file', 'my-dashboard.json') }}{% endraw %}"
  dashboardProviders:
    dashboardproviders.yaml:
      apiVersion: 1
      providers:
        - name: nvidia
          orgId: 1
          folder: NVIDIA
          type: file
          disableDeletion: false
          editable: true
          options:
            path: /var/lib/grafana/dashboards/nvidia

  dashboards:
    nvidia:
      dcgm-exporter:
        # Official NVIDIA DCGM dashboard from Grafana.com
        # https://grafana.com/grafana/dashboards/12239
        gnetId: 12239
        revision: 1
        datasource: Prometheus
{% endif %}

# ── Prometheus ─────────────────────────────────────────────────────────────────
prometheus:
  service:
    type: NodePort
    nodePort: {{ prometheus_nodeport }}

{% if deploy_dcgm | default(false) | bool %}
  prometheusSpec:
    # ── DCGM Exporter scrape config (GPU only) ─────────────────────────────
    # This block tells Prometheus how to discover and scrape the DCGM Exporter
    # pods. DCGM Exporter is NOT part of kube-prometheus-stack — it is a
    # separate DaemonSet we deploy ourselves via the dcgm_exporter role.
    #
    # Why we use additionalScrapeConfigs here instead of a ServiceMonitor CRD:
    #   ServiceMonitors are cleaner but require the Prometheus Operator to have
    #   permission to read them across namespaces. additionalScrapeConfigs is
    #   simpler and guaranteed to work with any Operator configuration.
    #
    # How it works:
    #   1. kubernetes_sd_configs discovers all pods in the monitoring namespace
    #   2. relabel_configs filters to only pods with label app=dcgm-exporter
    #   3. The pod IP is used as the scrape address on port {{ dcgm_metrics_port }}
    #   4. node and pod labels are attached so metrics are queryable per-node
    additionalScrapeConfigs:
      - job_name: dcgm-exporter
        scrape_interval: 15s
        metrics_path: /metrics
        kubernetes_sd_configs:
          - role: pod
            namespaces:
              names:
                - {{ dcgm_namespace }}
        relabel_configs:
          - source_labels: [__meta_kubernetes_pod_label_app]
            action: keep
            regex: dcgm-exporter
          - source_labels: [__meta_kubernetes_pod_ip]
            target_label: __address__
            replacement: $1:{{ dcgm_metrics_port }}
          - source_labels: [__meta_kubernetes_node_name]
            target_label: node
          - source_labels: [__meta_kubernetes_pod_name]
            target_label: pod
{% endif %}
