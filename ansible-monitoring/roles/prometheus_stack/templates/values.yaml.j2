# ansible-monitoring/roles/prometheus_stack/templates/values.yaml.j2
#
# This file customises the kube-prometheus-stack Helm chart.
# It is rendered by Ansible at deploy time into /tmp/monitoring-values.yaml
# and passed to `helm upgrade --install` via the -f flag.
#
# What the chart installs for us (we do not manage these directly):
#   - Prometheus            — metrics database and query engine
#   - Alertmanager          — alert routing and deduplication
#   - Grafana               — dashboard and visualisation UI
#   - Prometheus Operator   — manages Prometheus/Alertmanager as CRDs
#   - kube-state-metrics    — exposes Kubernetes object state as metrics
#   - node-exporter         — exposes per-node OS/hardware metrics
#
# What this file does:
#   - Sets NodePort values so Grafana and Prometheus are reachable externally
#   - Conditionally provisions Grafana dashboards for GPU monitoring
#   - Conditionally configures Prometheus to scrape DCGM Exporter
#
# GPU monitoring (DCGM) is OPTIONAL and controlled by deploy_dcgm at runtime.
# When deploy_dcgm=false (default), all GPU-specific blocks below are omitted.
# When deploy_dcgm=true, the DCGM scrape job and the NVIDIA dashboard are added.

# ── kube-state-metrics ────────────────────────────────────────────────────────
# By default kube-state-metrics only exposes pod labels that are explicitly
# allowlisted. JupyterHub pod labels are not in the default list, so
# kube_pod_labels never carries label_hub_jupyter_org_username — the Grafana
# username variable and per-user joins return empty even with active sessions.
#
# extraArgs adds these three labels to the allowlist:
#   label_hub_jupyter_org_username  — researcher's JupyterHub username
#   label_workbench_gitlab_group    — researcher's GitLab group
#   label_workbench_profile_slug    — the launched profile (cpu-only, gpu-small)
#
# After Helm upgrade, the username dropdown populates when notebooks are
# running, and per-user RAM/CPU panels correctly show real usernames.
kube-state-metrics:
  extraArgs:
    - --metric-labels-allowlist=pods=[hub.jupyter.org/username,workbench/gitlab-group,workbench/profile-slug]

# ── Grafana ────────────────────────────────────────────────────────────────────
grafana:
  service:
    type: NodePort
    nodePort: {{ grafana_nodeport }}

  # ── Dashboard provisioning ─────────────────────────────────────────────────
  # dashboardProviders defines all Grafana dashboard folders in one block.
  # YAML does not allow the same key twice — having two dashboardProviders
  # blocks causes the second to silently overwrite the first.
  # Both the workbench provider (always) and NVIDIA provider (DCGM only)
  # live here so Grafana sees both.
  dashboardProviders:
    dashboardproviders.yaml:
      apiVersion: 1
      providers:
        # AI Workbench dashboard — always provisioned
        - name: workbench
          orgId: 1
          folder: AI Workbench
          type: file
          disableDeletion: false
          editable: true
          options:
            path: /var/lib/grafana/dashboards/workbench
{% if deploy_dcgm | default(false) | bool %}
        # NVIDIA DCGM dashboard — only when DCGM is deployed
        - name: nvidia
          orgId: 1
          folder: NVIDIA
          type: file
          disableDeletion: false
          editable: true
          options:
            path: /var/lib/grafana/dashboards/nvidia
{% endif %}

  # dashboards: the actual dashboard definitions.
  # workbench-dashboard.json is read at Ansible render time via lookup('file').
  # Helm inlines it into a ConfigMap which Grafana mounts on startup.
  dashboards:
    workbench:
      workbench-monitor:
        json: |
          {{ lookup('file', 'workbench-dashboard.json') | indent(10) }}
{% if deploy_dcgm | default(false) | bool %}
    nvidia:
      dcgm-exporter:
        # Official NVIDIA DCGM Exporter dashboard — https://grafana.com/grafana/dashboards/12239
        gnetId: 12239
        revision: 1
        datasource: Prometheus
{% endif %}

# ── Prometheus ─────────────────────────────────────────────────────────────────
prometheus:
  service:
    type: NodePort
    nodePort: {{ prometheus_nodeport }}

  prometheusSpec:
    additionalScrapeConfigs:

      # ── Longhorn storage scrape (always enabled) ───────────────────────────
      # Longhorn Manager exposes metrics on port 9500, but only for the node
      # it runs on. A static service target only scrapes whichever pod the
      # load-balancer picks — giving metrics for one node only.
      # Pod-level discovery scrapes every Manager pod individually so all
      # nodes (ansibleworker1, w1-temp, w2-temp, etc.) appear in Prometheus.
      - job_name: longhorn
        scrape_interval: 30s
        metrics_path: /metrics
        kubernetes_sd_configs:
          - role: pod
            namespaces:
              names:
                - longhorn-system
        relabel_configs:
          - source_labels: [__meta_kubernetes_pod_label_app]
            action: keep
            regex: longhorn-manager
          - source_labels: [__meta_kubernetes_pod_ip]
            target_label: __address__
            replacement: $1:9500
          - source_labels: [__meta_kubernetes_pod_node_name]
            target_label: node

{% if deploy_dcgm | default(false) | bool %}
      # ── DCGM Exporter scrape (GPU only, enabled when deploy_dcgm=true) ────
      # DCGM Exporter is NOT part of kube-prometheus-stack — it is a separate
      # DaemonSet deployed by the dcgm_exporter role on GPU nodes only.
      # kubernetes_sd_configs discovers pods labelled app=dcgm-exporter and
      # relabel_configs stamps node and pod labels onto every metric so panels
      # can filter by node name in Grafana using {node="$node"}.
      - job_name: dcgm-exporter
        scrape_interval: 15s
        metrics_path: /metrics
        kubernetes_sd_configs:
          - role: pod
            namespaces:
              names:
                - {{ dcgm_namespace }}
        relabel_configs:
          - source_labels: [__meta_kubernetes_pod_label_app]
            action: keep
            regex: dcgm-exporter
          - source_labels: [__meta_kubernetes_pod_ip]
            target_label: __address__
            replacement: $1:{{ dcgm_metrics_port }}
          # Stamp the Kubernetes node name so panels can filter by node.
          # Do NOT relabel "pod" here — when DCGM Kubernetes mode is active,
          # DCGM sets pod/namespace/container labels itself from the kubelet
          # pod-resources API. Overwriting "pod" with the scraper pod name
          # (dcgm-exporter-*) would hide the real notebook pod attribution.
          - source_labels: [__meta_kubernetes_pod_node_name]
            target_label: node
{% endif %}
