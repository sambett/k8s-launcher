proxy:
  service:
    type: NodePort
    nodePorts:
      http: {{ jhub_nodeport }}

hub:
  config:
    JupyterHub:
      authenticator_class: gitlab
      shutdown_on_logout: true
      cookie_secure: false
      logout_redirect_url: "http://{{ jhub_gitlab_url | replace("http://","") }}/users/sign_in"
    GitLabOAuthenticator:
      oauth_callback_url: "http://{{ jhub_access_node_ip }}:{{ jhub_nodeport }}/hub/oauth_callback"
      gitlab_url: "{{ jhub_gitlab_url }}"
      scope:
        - read_user
        - api
        - openid
      username_claim: username
      enable_auth_state: true
    KubeSpawner:
      start_timeout: 300
      http_timeout: 120

  extraEnv:
    GITLAB_CLIENT_ID:
      valueFrom:
        secretKeyRef:
          name: gitlab-oauth-secret
          key: client_id
    GITLAB_CLIENT_SECRET:
      valueFrom:
        secretKeyRef:
          name: gitlab-oauth-secret
          key: client_secret
    GITLAB_URL:
      value: "{{ jhub_gitlab_url }}"
    REGISTRY_HOST:
      value: "{{ jhub_registry_host }}"
    REGISTRY_NAMESPACE:
      value: "{{ jhub_registry_namespace }}"

  extraVolumes:
    - name: profiles-config
      configMap:
        name: jupyterhub-profiles
  extraVolumeMounts:
    - name: profiles-config
      mountPath: /etc/jupyterhub/profiles

  extraConfig:
    00-prompt: |
      c.GitLabOAuthenticator.extra_authorize_params = {"prompt": "login"}
    00-crypt-key: |
      c.CryptKeeper.keys = [bytes.fromhex("{{ jhub_crypt_key }}")]

    00-check-allowed: |
      import json, os, logging, urllib.request
      from oauthenticator.gitlab import GitLabOAuthenticator
      log = logging.getLogger(__name__)

      def _groups_from_profiles():
          try:
              with open("/etc/jupyterhub/profiles/profiles.json") as f:
                  profiles = json.load(f)
              return {p["gitlab_group"] for p in profiles if p.get("gitlab_group")}
          except Exception as e:
              log.error("check_allowed: cannot read profiles.json: %s", e)
              return set()

      async def _check_allowed(self, username, auth_model):
          allowed_groups = _groups_from_profiles()
          if not allowed_groups:
              log.warning("check_allowed: profiles.json empty — denying %s", username)
              return False
          access_token = (auth_model.get("auth_state") or {}).get("access_token", "")
          if not access_token:
              log.warning("check_allowed: no access_token for %s", username)
              return False
          gitlab_url = os.environ.get("GITLAB_URL", "{{ jhub_gitlab_url }}")
          req = urllib.request.Request(
              f"{gitlab_url}/api/v4/groups?min_access_level=10&per_page=100",
              headers={"Authorization": f"Bearer {access_token}"}
          )
          try:
              with urllib.request.urlopen(req, timeout=5) as resp:
                  user_groups = {g["path"] for g in json.loads(resp.read())}
          except Exception as e:
              log.error("check_allowed: GitLab API failed for %s: %s", username, e)
              return False
          result = bool(user_groups & allowed_groups)
          log.info("check_allowed: user=%s groups=%s allowed=%s", username, user_groups, result)
          return result

      GitLabOAuthenticator.check_allowed = _check_allowed

    01-dynamic-profiles: |
      import json, os, logging
      log = logging.getLogger(__name__)

      async def profile_list(spawner):
          auth_state = await spawner.user.get_auth_state()
          if not auth_state:
              return []
          token = (auth_state.get("access_token") or
                   auth_state.get("gitlab_user", {}).get("access_token", ""))
          import urllib.request
          gitlab_url = os.environ.get("GITLAB_URL", "{{ jhub_gitlab_url }}")
          req = urllib.request.Request(
              f"{gitlab_url}/api/v4/groups?min_access_level=10&per_page=50",
              headers={"Authorization": f"Bearer {token}"}
          )
          try:
              with urllib.request.urlopen(req, timeout=5) as resp:
                  user_groups = {g["path"] for g in json.loads(resp.read())}
          except Exception as e:
              log.error("GitLab groups fetch failed: %s", e)
              return []
          try:
              with open("/etc/jupyterhub/profiles/profiles.json") as f:
                  all_profiles = json.load(f)
          except Exception as e:
              log.error("Failed to read profiles.json: %s", e)
              return []
          def build_profile(p):
              registry_host = os.environ.get("REGISTRY_HOST", "{{ jhub_registry_host }}")
              reg_ns        = os.environ.get("REGISTRY_NAMESPACE", "{{ jhub_registry_namespace }}")
              image_name    = p.get("image_name", "notebook-cpu")
              image_options = p.get("image_options", [])
              default_tag   = image_options[0] if image_options else "latest"
              gpu_count     = int(p.get("gpu", 0))
              kubespawner = {
                  "image":         f"{registry_host}/{reg_ns}/{image_name}:{default_tag}",
                  "image_pull_policy": "IfNotPresent",
                  "cpu_limit":     float(p.get("cpu_limit", 2)),
                  "cpu_guarantee": float(p.get("cpu_guarantee", 0.5)),
                  "mem_limit":     p.get("mem_limit", "4G"),
                  "mem_guarantee": p.get("mem_guarantee", "1G"),
                  "image_pull_secrets": ["gitlab-registry-secret"],
                  # Pod labels — read by Kyverno to enforce per-group GPU quotas.
                  # Kyverno matches on workbench/gitlab-group to find the right policy.
                  "extra_labels": {
                      "workbench/gitlab-group": p.get("gitlab_group", "unknown"),
                      "workbench/profile-slug":  p.get("slug", "unknown"),
                  },
              }
              if gpu_count > 0:
                  kubespawner["extra_resource_limits"] = {"nvidia.com/gpu": str(gpu_count)}
                  # FIX: Read the exact nodeSelector stored by workbench-admin at profile
                  # creation time instead of the old hardcoded {"accelerator": "nvidia"}.
                  #
                  # workbench-admin stores:
                  #   node_selector_key   = "nvidia.com/gpu.product"   (GFD label key)
                  #   node_selector_value = e.g. "NVIDIA-A2"            (exact GPU model)
                  #
                  # Kyverno's require-gpu-node-selector policy checks that every GPU pod
                  # carries nodeSelector["nvidia.com/gpu.product"]. The old accelerator
                  # label never satisfied that check so every GPU spawn was denied at
                  # admission. This was the root cause of the GPU scheduling mismatch.
                  ns_key   = p.get("node_selector_key",   "nvidia.com/gpu.product")
                  ns_value = p.get("node_selector_value", "")
                  if ns_value:
                      kubespawner["node_selector"] = {ns_key: ns_value}
              return {
                  "display_name":        p.get("display_name", "Profile"),
                  "description":         p.get("description", ""),
                  "slug":                p.get("slug", ""),
                  "kubespawner_override": kubespawner,
              }
          return [
              build_profile(p)
              for p in all_profiles
              if p.get("gitlab_group") in user_groups
          ]

      c.KubeSpawner.profile_list = profile_list
singleuser:
  storage:
    type: dynamic
    dynamic:
      storageClass: "{{ storage_class }}"
    capacity: "{{ user_storage_capacity }}"
    homeMountPath: /home/jovyan
  nodeSelector:
    kubernetes.io/os: linux
  extraEnv:
    JUPYTER_ENABLE_LAB: "yes"

cull:
  enabled: true
  timeout: 1200
  every: 300
  maxAge: 0
  users: false

ingress:
  enabled: false
