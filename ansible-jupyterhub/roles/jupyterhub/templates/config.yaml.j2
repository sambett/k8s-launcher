proxy:
  service:
    type: NodePort
    nodePorts:
      http: {{ jhub_nodeport }}

hub:
  config:
    JupyterHub:
      authenticator_class: gitlab
      shutdown_on_logout: true
      cookie_secure: false
      logout_redirect_url: "http://{{ jhub_gitlab_url | replace("http://","") }}/users/sign_in"
    GitLabOAuthenticator:
      oauth_callback_url: "http://{{ jhub_access_node_ip }}:{{ jhub_nodeport }}/hub/oauth_callback"
      gitlab_url: "{{ jhub_gitlab_url }}"
      scope:
        - read_user
        - api
        - openid
      username_claim: username
      enable_auth_state: true
    KubeSpawner:
      start_timeout: 300
      http_timeout: 120
      events_enabled: true

  extraEnv:
    GITLAB_CLIENT_ID:
      valueFrom:
        secretKeyRef:
          name: gitlab-oauth-secret
          key: client_id
    GITLAB_CLIENT_SECRET:
      valueFrom:
        secretKeyRef:
          name: gitlab-oauth-secret
          key: client_secret
    GITLAB_URL:
      value: "{{ jhub_gitlab_url }}"
    REGISTRY_HOST:
      value: "{{ jhub_registry_host }}"
    REGISTRY_NAMESPACE:
      value: "{{ jhub_registry_namespace }}"

  extraVolumes:
    - name: profiles-config
      configMap:
        name: jupyterhub-profiles
  extraVolumeMounts:
    - name: profiles-config
      mountPath: /etc/jupyterhub/profiles

  extraConfig:
    00-prompt: |
      c.GitLabOAuthenticator.extra_authorize_params = {"prompt": "login"}
    00-crypt-key: |
      c.CryptKeeper.keys = [bytes.fromhex("{{ jhub_crypt_key }}")]

    00-check-allowed: |
      import json, os, logging, urllib.request
      from oauthenticator.gitlab import GitLabOAuthenticator
      log = logging.getLogger(__name__)

      def _groups_from_profiles():
          try:
              with open("/etc/jupyterhub/profiles/profiles.json") as f:
                  profiles = json.load(f)
              return {p["gitlab_group"] for p in profiles if p.get("gitlab_group")}
          except Exception as e:
              log.error("check_allowed: cannot read profiles.json: %s", e)
              return set()

      async def _check_allowed(self, username, auth_model):
          allowed_groups = _groups_from_profiles()
          if not allowed_groups:
              log.warning("check_allowed: profiles.json empty — denying %s", username)
              return False
          access_token = (auth_model.get("auth_state") or {}).get("access_token", "")
          if not access_token:
              log.warning("check_allowed: no access_token for %s", username)
              return False
          gitlab_url = os.environ.get("GITLAB_URL", "{{ jhub_gitlab_url }}")
          req = urllib.request.Request(
              f"{gitlab_url}/api/v4/groups?min_access_level=10&per_page=100",
              headers={"Authorization": f"Bearer {access_token}"}
          )
          try:
              with urllib.request.urlopen(req, timeout=5) as resp:
                  user_groups = {g["path"] for g in json.loads(resp.read())}
          except Exception as e:
              log.error("check_allowed: GitLab API failed for %s: %s", username, e)
              return False
          result = bool(user_groups & allowed_groups)
          log.info("check_allowed: user=%s groups=%s allowed=%s", username, user_groups, result)
          return result

      GitLabOAuthenticator.check_allowed = _check_allowed

    01-dynamic-profiles: |
      import json, os, logging
      log = logging.getLogger(__name__)

      def _ram_steps(mem_guarantee, mem_limit):
          """
          Derive discrete RAM choices from admin-defined bounds.
          Returns a list of memory strings (e.g. ["4G","8G","16G"]) or None
          when min == max (no dropdown needed, fixed value used instead).

          Rules:
            - always includes exact minimum (mem_guarantee)
            - includes friendly intermediate sizes strictly inside the range
            - always includes exact maximum (mem_limit)

          Applies to ALL profile types (cpu and gpu alike).
          GPU profile floors are already enforced at save time in profiles.py,
          so mem_guarantee is already a safe lower bound before we get here.
          """
          import re as _re

          def _to_g(val):
              s = str(val).strip()
              m = _re.match(r'^([0-9.]+)\s*(G|Gi|M|Mi)?$', s, _re.IGNORECASE)
              if not m:
                  return None
              n = float(m.group(1))
              u = (m.group(2) or 'G').upper()
              if u in ('M', 'MI'):
                  return n / 1024.0
              return n  # G and Gi treated identically here

          lo = _to_g(mem_guarantee)
          hi = _to_g(mem_limit)

          # No dropdown if either value is unparseable or bounds are equal.
          if lo is None or hi is None or lo >= hi:
              return None

          # Candidate friendly sizes in G. Any that fall strictly between
          # lo and hi are included. lo and hi are always included regardless.
          candidates = [1, 2, 4, 6, 8, 12, 16, 24, 32, 48, 64, 96, 128]

          steps = [lo]
          for c in candidates:
              if lo < float(c) < hi:
                  steps.append(float(c))
          steps.append(hi)

          # Deduplicate while preserving order (lo == a candidate is possible)
          seen = set()
          deduped = []
          for v in steps:
              if v not in seen:
                  seen.add(v)
                  deduped.append(v)

          def _fmt(v):
              # Emit clean strings: "4G" not "4.0G"
              return (str(int(v)) + 'G') if v == int(v) else (str(v) + 'G')

          return [_fmt(v) for v in deduped]

      def _cpu_steps(cpu_guarantee, cpu_limit):
          """
          Derive discrete CPU choices from admin-defined bounds.
          Returns a list of strings (e.g. ["0.5","1","2","4"]) or None
          when min == max (no dropdown needed, fixed value used instead).
          Applies to all profile types (cpu and gpu alike).
          GPU profile CPU floors are enforced at save time in profiles.py
          so cpu_guarantee is already a safe lower bound before we get here.
          """
          try:
              lo = float(cpu_guarantee or 0.5)
              hi = float(cpu_limit or 2)
          except (TypeError, ValueError):
              return None
          if lo >= hi:
              return None
          candidates = [0.5, 1, 2, 4, 8, 16, 32]
          steps = [lo]
          for c in candidates:
              if lo < float(c) < hi:
                  steps.append(float(c))
          steps.append(hi)
          seen = set()
          deduped = []
          for v in steps:
              if v not in seen:
                  seen.add(v)
                  deduped.append(v)
          def _fmt(v):
              return str(int(v)) if v == int(v) else str(v)
          return [_fmt(v) for v in deduped]

      async def profile_list(spawner):
          auth_state = await spawner.user.get_auth_state()
          if not auth_state:
              return []
          token = (auth_state.get("access_token") or
                   auth_state.get("gitlab_user", {}).get("access_token", ""))
          import urllib.request
          gitlab_url = os.environ.get("GITLAB_URL", "{{ jhub_gitlab_url }}")
          req = urllib.request.Request(
              f"{gitlab_url}/api/v4/groups?min_access_level=10&per_page=50",
              headers={"Authorization": f"Bearer {token}"}
          )
          try:
              with urllib.request.urlopen(req, timeout=5) as resp:
                  user_groups = {g["path"] for g in json.loads(resp.read())}
          except Exception as e:
              log.error("GitLab groups fetch failed: %s", e)
              return []
          try:
              with open("/etc/jupyterhub/profiles/profiles.json") as f:
                  all_profiles = json.load(f)
          except Exception as e:
              log.error("Failed to read profiles.json: %s", e)
              return []

          def build_profile(p):
              registry_host = os.environ.get("REGISTRY_HOST", "{{ jhub_registry_host }}")
              reg_ns        = os.environ.get("REGISTRY_NAMESPACE", "{{ jhub_registry_namespace }}")
              image_name    = p.get("image_name", "notebook-cpu")
              image_options = p.get("image_options", [])
              default_tag   = image_options[0] if image_options else "latest"
              gpu_count     = int(p.get("gpu", 0))

              kubespawner = {
                  "image":             f"{registry_host}/{reg_ns}/{image_name}:{default_tag}",
                  "image_pull_policy": "IfNotPresent",
                  "image_pull_secrets": ["gitlab-registry-secret"],
                  # Pod labels — read by Kyverno to enforce per-group GPU quotas.
                  "extra_labels": {
                      "workbench/gitlab-group": p.get("gitlab_group", "unknown"),
                      "workbench/profile-slug":  p.get("slug", "unknown"),
                  },
              }

              # RAM: derive user-selectable steps from the admin-defined bounds.
              # When min == max, _ram_steps returns None and we fall through to
              # the fixed-value path — behaviour is identical to before this change.
              # When min != max, RAM values are provided via profile_options below
              # and must NOT be set here — the choice override takes effect instead.
              ram_steps = _ram_steps(
                  p.get("mem_guarantee", "1G"),
                  p.get("mem_limit",     "4G")
              )
              if not ram_steps:
                  # Fixed RAM — no dropdown rendered, pod always gets these values.
                  kubespawner["mem_limit"]     = p.get("mem_limit",     "4G")
                  kubespawner["mem_guarantee"] = p.get("mem_guarantee", "1G")

              # CPU: same bounded-choice model as RAM.
              # cpu_guarantee and cpu_limit are NOT in the static kubespawner
              # dict above — set conditionally here, same pattern as RAM.
              cpu_steps = _cpu_steps(
                  p.get("cpu_guarantee", 0.5),
                  p.get("cpu_limit",     2)
              )
              if not cpu_steps:
                  # Fixed CPU — no dropdown rendered, pod always gets these values.
                  kubespawner["cpu_limit"]     = float(p.get("cpu_limit",     2))
                  kubespawner["cpu_guarantee"] = float(p.get("cpu_guarantee", 0.5))

              # GPU-specific additions — only when profile has gpu > 0.
              # RAM freedom applies here too: GPU profile floors are enforced at
              # save time in profiles.py, so mem_guarantee is already safe.
              if gpu_count > 0:
                  kubespawner["extra_resource_limits"] = {"nvidia.com/gpu": str(gpu_count)}
                  ns_key   = p.get("node_selector_key",   "nvidia.com/gpu.product")
                  ns_value = p.get("node_selector_value", "")
                  if ns_value:
                      kubespawner["node_selector"] = {ns_key: ns_value}

              profile = {
                  "display_name":        p.get("display_name", "Profile"),
                  "description":         p.get("description", ""),
                  "slug":                p.get("slug", ""),
                  "kubespawner_override": kubespawner,
              }

              # Attach RAM dropdown when a range was defined.
              # Each choice overrides mem_limit and mem_guarantee on the pod.
              # Default is always the minimum (most conservative, admin floor).
              # GPU count, CPU, nodeSelector are untouched by this.
              if cpu_steps or ram_steps:
                  profile["profile_options"] = {}
                  if cpu_steps:
                      # Build choices explicitly so "default": True lands
                      # inside the first choice dict, not at the group level.
                      # KubeSpawner rejects "default" at the group level and
                      # silently drops the entire option — that was why the
                      # CPU dropdown never rendered.
                      cpu_choices = {}
                      for i, cores in enumerate(cpu_steps):
                          entry = {
                              "display_name": cores + " cores",
                              "kubespawner_override": {
                                  "cpu_limit":     float(cores),
                                  "cpu_guarantee": float(cores),
                              }
                          }
                          if i == 0:
                              entry["default"] = True
                          cpu_choices[cores] = entry
                      profile["profile_options"]["cpu"] = {
                          "display_name": "CPU",
                          "choices": cpu_choices,
                      }
                  if ram_steps:
                      # Same fix — "default": True inside first choice.
                      ram_choices = {}
                      for i, size in enumerate(ram_steps):
                          entry = {
                              "display_name": size,
                              "kubespawner_override": {
                                  "mem_limit":     size,
                                  "mem_guarantee": size,
                              }
                          }
                          if i == 0:
                              entry["default"] = True
                          ram_choices[size] = entry
                      profile["profile_options"]["ram"] = {
                          "display_name": "RAM",
                          "choices": ram_choices,
                      }

              return profile

          return [
              build_profile(p)
              for p in all_profiles
              if p.get("gitlab_group") in user_groups
          ]

      c.KubeSpawner.profile_list = profile_list

singleuser:
  storage:
    type: dynamic
    dynamic:
      storageClass: "{{ storage_class }}"
    capacity: "{{ user_storage_capacity }}"
    homeMountPath: /home/jovyan
  nodeSelector:
    kubernetes.io/os: linux
  extraEnv:
    JUPYTER_ENABLE_LAB: "yes"

cull:
  enabled: true
  timeout: 1200
  every: 300
  maxAge: 0
  users: false

ingress:
  enabled: false
