{
  "presets": {
    "stable-sprint2": {
      "kubernetes": "1.30.5",
      "containerd": "1.7.22",
      "calico": "v3.28.2",
      "longhorn": "1.7.2",
      "status": "validated"
    }
  },
  "rules": [
    {
      "if": {
        "kubernetes_lt": "1.25",
        "longhorn_major": "1.7"
      },
      "affects": "longhorn",
      "severity": "breaking",
      "message": "Longhorn requires Kubernetes 1.25 or higher.",
      "source_type": "official",
      "source_url": "https://longhorn.io/docs/latest/deploy/install/"
    }
  ],
  "nvidia_device_plugin": [
    {
      "version": "v0.17.4",
      "recommended": true,
      "notes": "Compatible with all Kubernetes versions >= 1.10",
      "toolkit_min": "1.7.0"
    },
    {
      "version": "v0.17.0",
      "notes": "Compatible with all Kubernetes versions >= 1.10",
      "toolkit_min": "1.7.0"
    },
    {
      "version": "v0.16.2",
      "notes": "Compatible with all Kubernetes versions >= 1.10",
      "toolkit_min": "1.7.0"
    }
  ],
  "kube_prometheus_stack": [
    {
      "version": "65.1.0",
      "k8s_min": "1.29",
      "k8s_max": "1.31",
      "notes": "Recommended for K8s 1.30.x"
    },
    {
      "version": "61.3.0",
      "k8s_min": "1.27",
      "k8s_max": "1.30",
      "notes": "Stable for K8s 1.27-1.29"
    },
    {
      "version": "58.4.0",
      "k8s_min": "1.25",
      "k8s_max": "1.28",
      "notes": "For K8s 1.25-1.27"
    }
  ],
  "kyverno": [
    {
      "version": "3.2.6",
      "k8s_min": "1.29",
      "k8s_max": "1.31",
      "notes": "Recommended for K8s 1.30.x"
    },
    {
      "version": "3.1.4",
      "k8s_min": "1.27",
      "k8s_max": "1.30",
      "notes": "Stable for K8s 1.27-1.29"
    },
    {
      "version": "3.0.5",
      "k8s_min": "1.25",
      "k8s_max": "1.28",
      "notes": "For K8s 1.25-1.27"
    }
  ],
  "dcgm_exporter": [
    {
      "version": "3.3.5-3.4.0-ubuntu22.04",
      "recommended": true,
      "notes": "Stable DCGM release \u2014 compatible with NVIDIA driver 590+ and CUDA 13.x"
    },
    {
      "version": "3.2.5-3.1.8-ubuntu22.04",
      "notes": "Previous stable release"
    }
  ]
}
