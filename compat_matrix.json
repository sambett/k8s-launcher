{
  "presets": {
    "stable-sprint2": {
      "kubernetes": "1.30.5",
      "containerd": "1.7.22",
      "calico": "v3.28.2",
      "longhorn": "1.7.2",
      "status": "validated"
    }
  },
  "rules": [
    {
      "if": {
        "containerd_major": "1.5"
      },
      "severity": "breaking",
      "message": "containerd 1.5.x is not supported on Kubernetes 1.24+. Use 1.7.x."
    },
    {
      "if": {
        "kubernetes_gte": "1.29"
      },
      "severity": "warning",
      "message": "Kubernetes 1.29+ requires containerd 1.7.0+. Verify your containerd version."
    },
    {
      "if": {
        "kubernetes_gte": "1.32"
      },
      "affects": "calico",
      "severity": "breaking",
      "message": "Calico 3.28 does not support Kubernetes 1.32+."
    },
    {
      "if": {
        "kubernetes_lt": "1.28"
      },
      "affects": "longhorn",
      "severity": "breaking",
      "message": "Longhorn 1.7 requires Kubernetes 1.28 or higher."
    }
  ],
  "nvidia_device_plugin": [
    {
      "version": "v0.17.4",
      "k8s_min": "1.29",
      "k8s_max": "1.31",
      "notes": "Recommended for K8s 1.30.x \u2014 latest stable"
    },
    {
      "version": "v0.17.0",
      "k8s_min": "1.29",
      "k8s_max": "1.31",
      "notes": "Stable for K8s 1.30.x"
    },
    {
      "version": "v0.16.2",
      "k8s_min": "1.27",
      "k8s_max": "1.30",
      "notes": "Previous stable release"
    }
  ],
  "kube_prometheus_stack": [
    {
      "version": "65.1.0",
      "k8s_min": "1.29",
      "k8s_max": "1.31",
      "notes": "Recommended for K8s 1.30.x"
    },
    {
      "version": "61.3.0",
      "k8s_min": "1.27",
      "k8s_max": "1.30",
      "notes": "Stable for K8s 1.27-1.29"
    },
    {
      "version": "58.4.0",
      "k8s_min": "1.25",
      "k8s_max": "1.28",
      "notes": "For K8s 1.25-1.27"
    }
  ],
  "kyverno": [
    {
      "version": "3.2.6",
      "k8s_min": "1.29",
      "k8s_max": "1.31",
      "notes": "Recommended for K8s 1.30.x"
    },
    {
      "version": "3.1.4",
      "k8s_min": "1.27",
      "k8s_max": "1.30",
      "notes": "Stable for K8s 1.27-1.29"
    },
    {
      "version": "3.0.5",
      "k8s_min": "1.25",
      "k8s_max": "1.28",
      "notes": "For K8s 1.25-1.27"
    }
  ]
}